<% layout("layouts/boilerplate") %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@300;400;500;700;800&display=swap');

  :root {
    --bg: #0A0A0A; --surface: #141414; --surface2: #1E1E1E;
    --text: #F5F0E8; --muted: #5A5A5A; --lime: #C9F53B;
    --border: rgba(245,240,232,0.08); --card-radius: 12px;
  }

  body { background: var(--bg); color: var(--text); font-family: 'Cabinet Grotesk', sans-serif; }

  .search-header {
    padding: 2rem 0 1rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 1.5rem;
  }

  .search-label {
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--lime); margin-bottom: 0.4rem;
  }

  .search-title {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-size: 1.8rem; font-weight: 800;
    color: var(--text); letter-spacing: -0.02em;
  }

  .search-title span { color: var(--lime); }

  .listing-link { text-decoration: none; color: inherit; display: block; }

  .card {
    border: 1px solid var(--border) !important;
    border-radius: var(--card-radius) !important;
    overflow: hidden;
    background: var(--surface) !important;
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .card:hover {
    transform: translateY(-6px);
    border-color: rgba(201,245,59,0.25) !important;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5) !important;
  }

  .card-img-wrapper { position: relative; overflow: hidden; }

  .card-img-top {
    height: 200px; width: 100%; object-fit: cover;
    transition: transform 0.6s; display: block;
  }

  .card:hover .card-img-top { transform: scale(1.05); }

  .card-badge-cat {
    position: absolute; top: 10px; left: 10px;
    background: rgba(10,10,10,0.75);
    backdrop-filter: blur(8px);
    color: var(--lime); font-size: 0.62rem;
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 3px 9px; border-radius: 4px;
    border: 1px solid rgba(201,245,59,0.2);
  }

  .card-body { padding: 0.8rem 0.9rem 1.2rem; background: var(--surface); }

  .card-title {
    font-family: 'Cabinet Grotesk', sans-serif; font-weight: 700;
    font-size: 0.88rem; color: var(--text); line-height: 1.3;
  }

  .card-price { font-size: 0.85rem; color: var(--muted); }
  .card-price strong { font-weight: 800; color: var(--text); font-size: 0.95rem; }

  .empty-state { text-align: center; padding: 5rem 1rem; }
  .empty-state i { font-size: 2.5rem; color: var(--muted); display: block; margin-bottom: 1rem; }
  .empty-state p { color: var(--muted); font-size: 1rem; }

  .btn-back {
    background: transparent; color: var(--text);
    border: 1px solid var(--border); border-radius: 6px;
    padding: 0.5rem 1.2rem; font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 700; font-size: 0.82rem; text-decoration: none;
    transition: all 0.2s; display: inline-block; margin-bottom: 1rem;
  }
  .btn-back:hover { border-color: var(--lime); color: var(--lime); }
</style>

<div class="container py-4">

  <a href="/listings" class="btn-back"><i class="fa-solid fa-arrow-left"></i> Back to All Listings</a>

  <div class="search-header">
    <p class="search-label"><i class="fa-solid fa-wand-magic-sparkles"></i> AI Search Results</p>
    <h1 class="search-title" id="searchTitle">Results for <span id="queryText"></span></h1>
    <p style="color:var(--muted);font-size:0.85rem;margin-top:0.3rem;" id="resultCount"></p>
  </div>

  <div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-1 g-2" id="resultsGrid">
    <!-- Cards authomatically added by JS based on search -->
  </div>

  <div id="emptyState" class="empty-state" style="display:none;">
    <i class="fa-solid fa-magnifying-glass"></i>
    <p>No listings found. Try a different search!</p>
  </div>

</div>

<script>
  const results = JSON.parse(sessionStorage.getItem("aiSearchResults") || "[]");
  const query   = sessionStorage.getItem("aiSearchQuery") || "";

  document.getElementById("queryText").textContent = `"${query}"`;
  document.getElementById("resultCount").textContent = `${results.length} listing${results.length !== 1 ? 's' : ''} found`;

  const grid = document.getElementById("resultsGrid");

  if(results.length === 0) {
    document.getElementById("emptyState").style.display = "block";
  } else {
    results.forEach(listing => {
      const imgUrl = listing.image?.url?.replace('/upload', '/upload/w_600,q_auto,f_auto') || '';
      grid.innerHTML += `
        <a href="/listings/${listing._id}" class="listing-link col">
          <div class="card h-100">
            <div class="card-img-wrapper">
              <img src="${imgUrl}" loading="lazy" class="card-img-top" alt="${listing.title}" />
              ${listing.category ? `<span class="card-badge-cat">${listing.category}</span>` : ''}
            </div>
            <div class="card-body">
              <p class="card-title mb-1">${listing.title}</p>
              <p class="card-price mb-0">
                <strong>₹ ${listing.price?.toLocaleString("en-IN")}</strong>
                <span style="font-size:0.82rem;"> / night</span>
              </p>
              <p style="font-size:0.78rem;color:var(--muted);margin-top:0.3rem;">
                <i class="fa-solid fa-location-dot"></i> ${listing.location}, ${listing.country}
              </p>
            </div>
          </div>
        </a>
      `;
    });
  }
</script>
