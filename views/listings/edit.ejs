<% layout("layouts/boilerplate") %>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@300;400;500;700;800&display=swap');

  :root {
    --bg: #0A0A0A; --surface: #141414; --surface2: #1E1E1E;
    --text: #F5F0E8; --muted: #5A5A5A; --lime: #C9F53B;
    --lime-dark: #b0d832; --border: rgba(245,240,232,0.08);
  }

  body { background: var(--bg); color: var(--text); font-family: 'Cabinet Grotesk', sans-serif; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .form-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; padding: 2.4rem 2rem;
    animation: fadeUp 0.6s ease both;
    max-width: 680px; margin: 2.5rem auto 4rem;
  }

  .form-page-title { font-family: 'Cabinet Grotesk', sans-serif; font-size: 2rem; font-weight: 800; color: var(--text); letter-spacing: -0.03em; margin-bottom: 0.3rem; }
  .form-page-sub { color: var(--muted); font-size: 0.88rem; margin-bottom: 2rem; }
  .form-label { font-family: 'Cabinet Grotesk', sans-serif; font-weight: 700; font-size: 0.78rem; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; }

  .section-mini-label {
    font-family: 'Cabinet Grotesk', sans-serif; font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--lime);
    margin-bottom: 0.8rem; margin-top: 1.6rem;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .section-mini-label::after { content: ''; flex: 1; height: 1px; background: rgba(201,245,59,0.15); }

  .form-control, .form-select {
    border: 1px solid var(--border); border-radius: 8px;
    font-family: 'Cabinet Grotesk', sans-serif; font-size: 0.9rem;
    padding: 0.65rem 1rem; background: var(--surface2) !important;
    color: var(--text) !important; transition: border-color 0.2s;
  }
  .form-control:focus, .form-select:focus {
    border-color: var(--lime); box-shadow: 0 0 0 2px rgba(201,245,59,0.1); outline: none;
  }
  .form-control::placeholder { color: var(--muted) !important; }
  .form-select option { background: var(--surface2); color: var(--text); }

  .input-icon-wrap { position: relative; }
  .input-icon-wrap i { position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 0.88rem; pointer-events: none; }
  .input-icon-wrap .form-control { padding-left: 2.6rem; }

  .img-preview-wrap {
    border-radius: 10px; overflow: hidden;
    border: 1px solid var(--border); margin-bottom: 0.5rem; position: relative;
  }
  .img-preview-wrap img { width: 100%; height: 200px; object-fit: cover; display: block; filter: brightness(0.9); }
  .img-preview-label {
    position: absolute; top: 10px; left: 12px;
    background: rgba(10,10,10,0.8); backdrop-filter: blur(8px);
    color: var(--lime); font-family: 'Cabinet Grotesk', sans-serif;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 3px 10px; border-radius: 4px; border: 1px solid rgba(201,245,59,0.2);
  }

  .btn-save {
    background: var(--lime); color: #0A0A0A; border: none;
    font-family: 'Cabinet Grotesk', sans-serif; font-weight: 800; font-size: 0.95rem;
    border-radius: 8px; padding: 0.8rem 2.4rem;
    transition: all 0.2s; cursor: pointer; width: 100%; letter-spacing: 0.02em;
  }
  .btn-save:hover { background: var(--lime-dark); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(201,245,59,0.2); }

  .invalid-feedback { font-size: 0.78rem; color: #ff6b6b; }
  .valid-feedback { font-size: 0.78rem; color: var(--lime); }
</style>

<div class="container">
  <div class="form-card">
    <h2 class="form-page-title">Edit Listing</h2>
    <p class="form-page-sub">Update your listing details below</p>

    <form method="post" action="/listings/<%= listing._id %>?_method=PUT" class="needs-validation" novalidate enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label">Title</label>
        <input type="text" class="form-control" name="listing[title]" value="<%= listing.title %>" required>
        <div class="valid-feedback">Looks good!</div>
        <div class="invalid-feedback">Title is required</div>
      </div>
      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" rows="3" required><%= listing.description %></textarea>
        <div class="invalid-feedback">Short description required</div>
      </div>
      <div class="mb-3">
        <label class="form-label">Current Image</label>
        <div class="img-preview-wrap">
          <img src="<%= originaLlImageUrl %>" alt="Current image">
          <span class="img-preview-label">Current</span>
        </div>
      </div>
      <div class="mb-3">
        <label class="form-label">Upload New Image <span style="color:var(--muted);font-weight:400;text-transform:none;letter-spacing:0;">(optional)</span></label>
        <input type="file" class="form-control" name="listing[image]">
      </div>
      <div class="mb-3">
        <label class="form-label">Price per Night (₹)</label>
        <div class="input-icon-wrap">
          <i class="fa-solid fa-indian-rupee-sign"></i>
          <input type="number" class="form-control" name="listing[price]" value="<%= listing.price %>" required>
        </div>
        <div class="invalid-feedback">Enter a valid price</div>
      </div>

      <p class="section-mini-label">Location</p>
      <div class="row g-3 mb-3">
        <div class="col-md-4">
          <label class="form-label">Country</label>
          <div class="input-icon-wrap">
            <i class="fa-solid fa-earth-asia"></i>
            <input type="text" class="form-control" name="listing[country]" value="<%= listing.country %>" required>
          </div>
          <div class="invalid-feedback">Enter a country</div>
        </div>
        <div class="col-md-8">
          <label class="form-label">City / Location</label>
          <div class="input-icon-wrap">
            <i class="fa-solid fa-location-dot"></i>
            <input type="text" class="form-control" name="listing[location]" value="<%= listing.location %>" required>
          </div>
          <div class="invalid-feedback">Enter a location</div>
        </div>
      </div>

      <div class="mb-4">
        <label class="form-label">Category</label>
        <select name="listing[category]" class="form-select" required>
          <option value="" disabled>Select a category</option>
          <option value="Trending"     <%= listing.category==='Trending'     ?'selected':'' %>>🔥 Trending</option>
          <option value="Rooms"        <%= listing.category==='Rooms'        ?'selected':'' %>>🛏 Rooms</option>
          <option value="IconicCities" <%= listing.category==='IconicCities' ?'selected':'' %>>🏙 Iconic Cities</option>
          <option value="Mountains"    <%= listing.category==='Mountains'    ?'selected':'' %>>⛰ Mountains</option>
          <option value="AmazingPools" <%= listing.category==='AmazingPools' ?'selected':'' %>>🏊 Pools</option>
          <option value="Camping"      <%= listing.category==='Camping'      ?'selected':'' %>>⛺ Camping</option>
          <option value="Beach"        <%= listing.category==='Beach'        ?'selected':'' %>>🏖 Beach</option>
          <option value="Farms"        <%= listing.category==='Farms'        ?'selected':'' %>>🐄 Farms</option>
        </select>
      </div>

      <button class="btn-save" type="submit">Save Changes <i class="fa-solid fa-arrow-right"></i></button>
    </form>
  </div>
</div>