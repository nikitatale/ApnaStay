<style>
  @import url('https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Cabinet+Grotesk:wght@300;400;500;700;800&display=swap');

  :root {
    --bg: #0A0A0A;
    --surface: #141414;
    --surface2: #1E1E1E;
    --text: #F5F0E8;
    --muted: #5A5A5A;
    --lime: #C9F53B;
    --lime-dark: #b0d832;
    --border: rgba(245,240,232,0.08);
  }

  * { box-sizing: border-box; }

  body {
    background: var(--bg) !important;
    color: var(--text) !important;
    font-family: 'Cabinet Grotesk', sans-serif !important;
  }

  .apna-nav {
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 0.7rem 0;
    position: sticky;
    top: 0;
    z-index: 999;
  }

  .apna-nav .navbar-brand img {
    height: 48px;
    transition: transform 0.3s;
    filter: brightness(0) invert(1);
  }

  .apna-nav .navbar-brand img:hover { transform: scale(1.05); }

  .nav-search-form {
    display: flex;
    align-items: center;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.3rem 0.4rem 0.3rem 1rem;
    gap: 0.4rem;
    transition: border-color 0.2s;
  }

  .nav-search-form:focus-within {
    border-color: var(--lime);
  }

  .nav-search-form input {
    border: none; outline: none;
    background: transparent;
    font-family: 'Cabinet Grotesk', sans-serif;
    font-size: 0.88rem;
    color: var(--text);
    width: 200px;
  }

  .nav-search-form input::placeholder { color: var(--muted); }

  .nav-search-btn {
    background: var(--lime);
    border: none; color: #0A0A0A;
    padding: 0.4rem 1rem;
    border-radius: 4px;
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 700; font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.2s;
    display: flex; align-items: center; gap: 0.4rem;
  }

  .nav-search-btn:hover { background: var(--lime-dark); transform: scale(1.03); }

  .apna-nav .nav-link {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 500; font-size: 0.88rem;
    color: var(--text) !important;
    padding: 0.4rem 0.8rem !important;
    border-radius: 4px;
    transition: all 0.2s;
    letter-spacing: 0.01em;
  }

  .apna-nav .nav-link:hover {
    color: var(--lime) !important;
    background: rgba(201,245,59,0.06);
  }

  .btn-nav-login {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 700; font-size: 0.85rem;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.42rem 1.2rem;
    background: transparent;
    transition: all 0.2s;
    text-decoration: none;
  }

  .btn-nav-login:hover {
    border-color: var(--lime);
    color: var(--lime);
  }

  .btn-nav-signup {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 700; font-size: 0.85rem;
    color: #0A0A0A;
    background: var(--lime);
    border: none; border-radius: 6px;
    padding: 0.42rem 1.2rem;
    transition: all 0.2s;
    text-decoration: none;
  }

  .btn-nav-signup:hover {
    background: var(--lime-dark);
    color: #0A0A0A;
    transform: scale(1.03);
  }

  .btn-nav-logout {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 700; font-size: 0.85rem;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.42rem 1.2rem;
    background: transparent;
    transition: all 0.2s;
    text-decoration: none;
  }

  .btn-nav-logout:hover { border-color: #ff4444; color: #ff4444; }

  .user-pill {
    display: flex; align-items: center; gap: 0.5rem;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.3rem 0.9rem 0.3rem 0.4rem;
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 700; font-size: 0.82rem;
    color: var(--text);
  }

  .user-avatar {
    width: 28px; height: 28px;
    background: var(--lime);
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    color: #0A0A0A; font-size: 0.78rem; font-weight: 800;
    font-family: 'Cabinet Grotesk', sans-serif;
  }

  .navbar-toggler {
    border: 1px solid var(--border) !important;
    border-radius: 6px !important;
  }

  .navbar-toggler-icon {
    filter: invert(1);
  }

  .navbar-toggler:focus { box-shadow: 0 0 0 2px rgba(201,245,59,0.3) !important; }

  @media (max-width: 767px) {
    .nav-search-form { width: 100%; margin: 0.6rem 0; }
    .nav-search-form input { width: 100%; }
    .apna-nav .navbar-nav { gap: 0.4rem; padding-bottom: 0.8rem; }
  }
</style>

<nav class="apna-nav navbar navbar-expand-md">
  <div class="container">
    <a class="navbar-brand" href="/listings">
      <img src="/assets/Apna_Stay-logo.png" alt="ApnaStay Logo">
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#apnaNavbar">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="apnaNavbar">
    <form class="nav-search-form ms-4 me-auto d-none d-md-flex" role="search" onsubmit="handleAiSearch(event)">
     <i class="fa-solid fa-magnifying-glass" style="color:var(--muted);font-size:0.85rem;"></i>
     <input type="search" id="navSearchInput" placeholder="Try: beach under 2000..." />
    <button type="submit" class="nav-search-btn">Search</button>
   </form>

      <ul class="navbar-nav align-items-center gap-1 ms-auto">
        <li class="nav-item">
          <a class="nav-link" href="/listings">Explore</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/listings/new"><i class="fa-solid fa-plus"></i> Become a Host</a>
        </li>

        <% if(!currUser) { %>
          <li class="nav-item ms-2">
            <a class="btn-nav-login" href="/login">Login</a>
          </li>
          <li class="nav-item ms-2">
            <a class="btn-nav-signup" href="/signup">Signup</a>
          </li>
        <% } %>

        <% if(currUser) { %>
          <li class="nav-item ms-2">
            <div class="user-pill">
              <div class="user-avatar"><%= currUser.username[0].toUpperCase() %></div>
              <%= currUser.username %>
            </div>
          </li>
          <li class="nav-item ms-2">
            <a class="btn-nav-logout" href="/logout">Logout</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>


<script>
  async function handleAiSearch(e) {
    e.preventDefault();
    const query = document.getElementById("navSearchInput").value.trim();
    if(!query) return;

    // loading
    const btn = document.querySelector(".nav-search-btn");
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Wait';
    btn.disabled = true;

    try {
      const res = await fetch("/ai-search", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ query })
      });

      const data = await res.json();

      if(data.listings.length === 0) {
        alert("No listings found for your search!");
        btn.textContent = "Search";
        btn.disabled = false;
        return;
      }

      // Store results in sessionStorage
      sessionStorage.setItem("aiSearchResults", JSON.stringify(data.listings));
      sessionStorage.setItem("aiSearchQuery", query);

      // Redirect to search results page
      window.location.href = "/listings/ai-results";

    } catch(err) {
      alert("Search failed, try again!");
    }

    btn.textContent = "Search";
    btn.disabled = false;
  }
</script>