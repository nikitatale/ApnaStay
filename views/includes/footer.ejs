<style>
  @import url('https://fonts.googleapis.com/css2?family=Cabinet+Grotesk:wght@300;400;500;700;800&display=swap');

  .apna-footer {
    background: #0A0A0A;
    border-top: 1px solid rgba(245,240,232,0.08);
    font-family: 'Cabinet Grotesk', sans-serif;
    padding: 3.5rem 0 0;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: 1200px; margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr;
    gap: 3rem;
  }

  .footer-brand-logo {
    height: 44px;
    filter: brightness(0) invert(1);
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  .footer-brand p {
    font-size: 0.88rem; color: #5A5A5A;
    line-height: 1.8; max-width: 280px;
  }

  .footer-col h4 {
    font-family: 'Cabinet Grotesk', sans-serif;
    font-weight: 800; font-size: 0.72rem;
    letter-spacing: 0.15em; text-transform: uppercase;
    color: #C9F53B; margin-bottom: 1.2rem;
  }

  .footer-col ul {
    list-style: none; padding: 0; margin: 0;
  }

  .footer-col ul li { margin-bottom: 0.7rem; }

  .footer-col ul li a {
    text-decoration: none; color: #5A5A5A;
    font-size: 0.88rem; font-weight: 500;
    transition: color 0.2s;
  }

  .footer-col ul li a:hover { color: #F5F0E8; }

  .social-links { display: flex; gap: 0.8rem; margin-top: 0.5rem; }

  .social-btn {
    width: 38px; height: 38px;
    background: #141414;
    border: 1px solid rgba(245,240,232,0.08);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #5A5A5A; font-size: 1rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .social-btn:hover {
    border-color: #C9F53B;
    color: #C9F53B;
    transform: translateY(-3px);
  }

  .footer-bottom {
    border-top: 1px solid rgba(245,240,232,0.06);
    margin-top: 3rem; padding: 1.2rem 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 0.5rem;
    max-width: 1200px; margin-left: auto; margin-right: auto;
  }

  .footer-bottom p {
    font-size: 0.78rem; color: #3A3A3A; margin: 0;
  }

  .footer-bottom-badge {
    font-size: 0.72rem; color: #3A3A3A;
    display: flex; align-items: center; gap: 0.4rem;
  }

  .footer-bottom-badge span {
    color: #C9F53B; font-weight: 700;
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 480px) {
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>

<footer class="apna-footer">
  <div class="footer-inner">

    <div class="footer-brand">
      <img src="/assets/Apna_Stay-logo.png" alt="ApnaStay" class="footer-brand-logo">
      <p>Connecting travelers with the best stays across India. Your comfort and safety are our top priority.</p>
    </div>

    <div class="footer-col">
      <h4>Explore</h4>
      <ul>
        <li><a href="/listings">All Listings</a></li>
        <li><a href="/listings/new">Become a Host</a></li>
        <li><a href="/login">Login</a></li>
        <li><a href="/signup">Sign Up</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Follow Us</h4>
      <div class="social-links">
        <a href="#" class="social-btn"><i class="fa-brands fa-github"></i></a>
        <a href="#" class="social-btn"><i class="fa-brands fa-linkedin-in"></i></a>
        <a href="#" class="social-btn"><i class="fa-brands fa-twitter"></i></a>
      </div>
    </div>

  </div>

  <div class="footer-bottom">
    <p>&copy; 2025 ApnaStay Private Limited. All Rights Reserved.</p>
    <div class="footer-bottom-badge"><span><i class="fa-solid fa-heart"></i></span> Nikita Tale</div>
  </div>
</footer>